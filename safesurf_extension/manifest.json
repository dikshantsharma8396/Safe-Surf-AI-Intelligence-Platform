{
  "manifest_version": 3,
  "name": "Safe-Surf AI Sentinel",
  "version": "1.3",
  "description": "Real-time Phishing Detection, Web Intervention, and Access Restriction.",
  "developer": {
    "name": "Dikshant Sharma"
  },
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "scripting",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}